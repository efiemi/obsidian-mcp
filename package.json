{
  "name": "obsidian-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/main.ts",
    "start": "node dist/src/main.js",
    "start:mcp": "node dist/src/mcp_stdio.js",
    "dev:mcp": "npm run -s build && node dist/src/mcp_stdio.js",
    "ingest": "tsx scripts/ingest-vault.ts"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.888.0",
    "axios": "^1.11.0",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@types/node": "^24.4.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
